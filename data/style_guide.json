{
  "version": 1,
  "updated_at": "2026-06-24",
  "title": "AES 中文表述规范",
  "description": "适用于标题翻译、AI 导读、摘要直译等一切中文生成环节。8300 文档维护编辑；流水线经 style_guide_loader.py 读取本 JSON",
  "word_variants": [
    {
      "id": "core",
      "limit": [
        "核心"
      ],
      "prefer": [
        "主要、关键、要点、重点、首要"
      ],
      "note": "避免段段出现「核心」；按语境选用同义表述"
    },
    {
      "id": "crucial",
      "limit": [
        "至关重要"
      ],
      "prefer": [
        "十分重要、尤为值得注意、需重点关注、影响较大"
      ],
      "note": "降调 AI 惯用强调语"
    },
    {
      "id": "although",
      "limit": [
        "尽管"
      ],
      "prefer": [
        "虽然、尽管"
      ],
      "note": "二者可互换，同篇内勿机械重复同一连接词"
    },
    {
      "id": "demonstrate",
      "limit": [
        "最大化"
      ],
      "prefer": [
        "尽量"
      ],
      "note": "maximize 直译为 最大化 比较生硬 应选择适应上下文的地道表述 如 尽量"
    }
  ],
  "terminology": [
    {
      "id": "ha",
      "avoid": [
        "玻尿酸"
      ],
      "prefer": "透明质酸",
      "english": "hyaluronic acid",
      "note": "首次出现写「透明质酸（hyaluronic acid）」；具体商品名保留英文/注册名"
    },
    {
      "id": "botulinum",
      "avoid": [
        "肉毒素、肉毒"
      ],
      "prefer": "肉毒毒素",
      "english": "botulinum toxin",
      "note": "首次出现可写「肉毒毒素（botulinum toxin）」"
    },
    {
      "id": "prp",
      "avoid": [
        "富血小板血浆疗法"
      ],
      "prefer": "富血小板血浆（PRP）",
      "english": "platelet-rich plasma",
      "note": "与原文 PLATELET-RICH PLASMA 一致时可保留 PRP"
    },
    {
      "id": "laser",
      "avoid": [],
      "prefer": "激光",
      "english": "laser",
      "note": "具体设备名、波长、脉宽按原文，不随意简写"
    },
    {
      "id": "filler",
      "avoid": [
        "填充物"
      ],
      "prefer": "填充剂",
      "english": "filler",
      "note": "指注射用产品时"
    },
    {
      "id": "adverse_event",
      "avoid": [
        "副作用"
      ],
      "prefer": "不良事件",
      "english": "adverse event",
      "note": "临床文献语境优先「不良事件」；口语化场景可酌情"
    }
  ],
  "syntax_rules": [
    {
      "id": "de_machine",
      "title": "减少机翻感",
      "rules": [
        "在准确前提下，用长句拆短、短句合并，调整语序，主被动语态与原文不必一一对应",
        "避免「被…所…」「进行了…的研究」等翻译腔叠床架屋",
        "同一段内避免重复同一主语开头"
      ]
    },
    {
      "id": "clarity",
      "title": "表意明确",
      "rules": [
        "模糊或生僻概念改用明确、易懂的说法，但不改变医学含义",
        "指代清晰：「该组」「上述方法」须能对应到具体组名或步骤",
        "数字、单位、随访时间点与原文一致，不省略关键限定词"
      ]
    },
    {
      "id": "proper_nouns",
      "title": "专有名词",
      "rules": [
        "人名、地名、机构、产品、公司名不翻译，保留英文",
        "专业术语：中文后括号注明英文，如「透明质酸（hyaluronic acid）」",
        "数字与中文之间不空格（如 3 个月、50%）"
      ]
    },
    {
      "id": "tone",
      "title": "语气",
      "rules": [
        "导读用平实陈述，不用社论式、营销式语气",
        "不做个体化治疗建议；用「该研究显示…」「作者认为…」",
        "禁止「你应该」「推荐采用」「务必」等指令式表述"
      ]
    }
  ],
  "scopes": [
    {
      "id": "reading_note",
      "label": "AI 导读（中间页）",
      "inject": true
    },
    {
      "id": "title_zh",
      "label": "标题翻译",
      "inject": true
    },
    {
      "id": "abstract_translate",
      "label": "摘要直译",
      "inject": true
    },
    {
      "id": "full_translate",
      "label": "全文翻译（MSDC/FUL 等）",
      "inject": true
    }
  ]
}