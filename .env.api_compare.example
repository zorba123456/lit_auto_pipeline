# API 比选密钥 — 复制为 .env.api_compare 并填入真实值
#   cp .env.api_compare.example .env.api_compare
# 验证：python3 open_compare_api.py --verify
#       python3 scripts/verify_api_compare.py

# ── Gemini（Google AI Studio）────────────────────────────
# 获取：https://aistudio.google.com/apikey
# Pro Google 账号常有免费额度（见控制台 Quotas）；比选须分别测 2.5 与 3.5
GEMINI_API_KEY=

# ── DeepSeek ─────────────────────────────────────────────
# 获取：https://platform.deepseek.com → API Keys → 创建
# 充值后按量；比选用 deepseek-v4-flash（thinking 默认开）与 deepseek-v4-pro
DEEPSEEK_API_KEY=

# ── 豆包 / 火山方舟 Ark ──────────────────────────────────
# 获取：https://console.volcengine.com/ark → API Key 管理
ARK_API_KEY=

# 推理接入点 ID（ep- 开头，填到 API 的 model 字段，不是模型名字符串）
# 示例：控制台显示 aas-lite-32k → ep-20250525113859-xmhhh
# 亦可新建 Doubao-Seed-Evolving 接入点，改 ARK_ENDPOINT 即可
ARK_ENDPOINT=ep-20260625113959-xmtbh

# 兼容旧变量名（可选，与 ARK_ENDPOINT 二选一）
# ARK_ENDPOINT_LITE_32K=ep-20250525113859-xmhhh
