# ==============================================================================
# 1. 昼夜状态自动切换守护（当天 07:00 进入 MANUAL 保护模式，第二天 01:00 进入 AUTO 自动化模式）
# ==============================================================================
0 1 * * * echo "AUTO" > /Users/meiyiwangluokeji/coding/lit_auto_pipeline/.status
0 7 * * * echo "MANUAL" > /Users/meiyiwangluokeji/coding/lit_auto_pipeline/.status

# ==============================================================================
# 2. 全局半点、整点心跳（唯一触发源，进入后由 run_task.sh 门禁做权限判读）
# ==============================================================================
0,30 * * * * /Users/meiyiwangluokeji/coding/lit_auto_pipeline/run_all.sh

# ==============================================================================
# 3. 知网深度抓取 (带持久弹窗的人工介入确认)
# ==============================================================================
# 错峰执行：延后5分钟，避开整点 run_all.sh 的锁冲突
5 10,17 * * * /Users/meiyiwangluokeji/coding/lit_auto_pipeline/prompt_cnki_web.sh

# ==============================================================================
# 4. LWW 独立任务
# ==============================================================================
# 错峰执行：延后10分钟，避开整点锁冲突
10 */4 * * * /Users/meiyiwangluokeji/coding/lit_auto_pipeline/run_task.sh lww

# ===================================================
# 5. crontab 自动备份到项目目录（含 git push）
# ===================================================
# 先用 diff 判断是否有变更，有变更才 commit + push，避免每天产生空commit
5 3 * * * cd /Users/meiyiwangluokeji/coding/lit_auto_pipeline && crontab -l > crontab.backup.new && if ! diff crontab.backup crontab.backup.new >/dev/null 2>&1; then mv crontab.backup.new crontab.backup && git add crontab.backup && git commit -m "chore: auto-sync crontab backup [$(date +\%F)]" && git push; else rm -f crontab.backup.new; fi

# ===================================================
# 6. wechat_rss venv 兜底检查（每小时一次，确保自启动不出问题）
# ===================================================
0 * * * * /Users/meiyiwangluokeji/coding/wechat_rss/ensure_venv.sh

# ================ EOF ================
